<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\SimpleHexEditor.ico</ApplicationIcon>
    <AssemblyName>SimpleHexEditor</AssemblyName>
    <RootNamespace>SimpleHexEditor</RootNamespace>
    <Version>0.1.0</Version>
    <FileVersion>0.1.0.0</FileVersion>
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
  </PropertyGroup>
  <ItemGroup>
    <Resource Include="Assets\SimpleHexEditor.ico" />
    <Content Include="..\Store-Assets\Logo-50x50.png" Link="Assets\\Logo-50x50.png" />
  </ItemGroup>
</Project>
