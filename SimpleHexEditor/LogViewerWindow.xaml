<Window x:Class="SimpleHexEditor.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Hex Editor Logs"
        Width="900"
        Height="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox x:Name="LogText" Grid.Row="0" FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True" AcceptsTab="True" />
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Refresh" Width="110" Margin="0,0,10,0" Click="OnRefresh" />
            <Button Content="Close" Width="110" Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
