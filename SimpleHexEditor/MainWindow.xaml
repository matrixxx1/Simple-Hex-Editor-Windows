<Window x:Class="SimpleHexEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Hex Editor"
        Width="1320"
        Height="840"
        MinWidth="1120"
        MinHeight="760"
        Background="#F8FAFC">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Background" Value="#475569" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="FeatureText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="InputRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="22" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#475569" Padding="28,24">
            <StackPanel>
                <TextBlock Text="Simple Hex Editor" Foreground="White" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="Open a file, inspect bytes, edit values, search patterns, and export/share forensic-friendly dumps." Foreground="#E0F2FE" FontSize="16" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

    <Grid Grid.Row="1" Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Hex Workspace" FontSize="21" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Grid.Row="1" Text="Load a file then move quickly: search bytes, navigate by offset, edit values, bookmark key locations, and export a compact dump." TextWrapping="Wrap" Foreground="#475569" FontSize="14" Margin="0,8,0,14" />

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Vertical">
                            <StackPanel Style="{StaticResource InputRow}">
                                <Button x:Name="OpenFileButton" Content="Open File" Click="OnOpenFile" Width="135" />
                                <Button x:Name="ReloadFileButton" Content="Reload File" Click="OnReloadFile" Width="135" />
                                <Button x:Name="SaveButton" Content="Save Changes" Click="OnSaveFile" Width="135" />
                                <Button x:Name="ExportDumpButton" Content="Export Hex Dump" Click="OnExportHexDump" Width="135" />
                            </StackPanel>
                            <Separator Margin="0,8,0,10" />
                            <StackPanel Style="{StaticResource InputRow}">
                                <TextBlock Text="Search hex:" VerticalAlignment="Center" Width="95" />
                                <TextBox x:Name="SearchText" Width="220" Margin="0,0,12,0" />
                                <Button Content="Find" Click="OnFindBytes" Width="95" />
                                <Button Content="Next" Click="OnFindNext" Width="95" />
                                <Button Content="Clear" Click="OnClearSearch" Width="95" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource InputRow}">
                            <TextBlock Text="Go to offset:" VerticalAlignment="Center" Width="95" />
                            <TextBox x:Name="GotoOffsetText" Width="220" Margin="0,0,12,0" />
                            <Button Content="Go" Click="OnGoToOffset" Width="95" />
                            <Button Content="Copy selected row" Click="OnCopyRow" Width="140" />
                            <Button Content="Copy selection" Click="OnCopySelection" Width="130" />
                        </StackPanel>
                            <StackPanel Style="{StaticResource InputRow}">
                                <Button Content="Open Sample File" Click="OnOpenSampleFile" Width="145" />
                                <TextBlock Text="Edit byte @offset:" VerticalAlignment="Center" Width="130" />
                                <TextBox x:Name="EditOffsetText" Width="150" Margin="0,0,8,0" />
                                <TextBox x:Name="EditHexValueText" Width="90" Margin="0,0,8,0" />
                                <Button x:Name="ApplyEditButton" Content="Apply" Click="OnApplyByteEdit" Width="85" />
                                <Button x:Name="UndoButton" Content="Undo" Click="OnUndoEdit" Width="85" />
                                <Button x:Name="RedoButton" Content="Redo" Click="OnRedoEdit" Width="85" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource InputRow}">
                                <CheckBox x:Name="DiffModeEnabled" Content="Diff mode" VerticalAlignment="Center" Margin="0,0,18,0" IsChecked="True" Checked="OnDiffModeToggled" Unchecked="OnDiffModeToggled" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource InputRow}">
                                <TextBlock Text="Bookmark offset:" VerticalAlignment="Center" Width="130" />
                                <TextBox x:Name="BookmarkText" Width="150" Margin="0,0,8,0" />
                                <Button x:Name="AddBookmarkButton" Content="Add" Click="OnAddBookmark" Width="85" />
                                <Button x:Name="RemoveBookmarkButton" Content="Remove" Click="OnRemoveBookmark" Width="85" />
                                <Button x:Name="GotoBookmarkButton" Content="Jump" Click="OnGotoBookmark" Width="85" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource InputRow}">
                                <Button Content="Compute Checksums" Click="OnComputeChecksums" Width="145" />
                                <Button Content="Clear Workspace" Click="OnClearWorkspace" Width="145" />
                                <TextBlock x:Name="MatchInfo" Text="No matches" VerticalAlignment="Center" Foreground="#475569" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,12,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="88" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Bookmarks" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6" />
                            <ListBox x:Name="BookmarksList" Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" />
                        </Grid>

                        <DataGrid x:Name="ByteGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  FontFamily="Consolas"
                                  FontSize="14"
                                  SelectionChanged="OnSelectionChanged">
                            <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                                        <Setter Property="Background" Value="#FECDD3" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMatch}" Value="True">
                                        <Setter Property="Background" Value="#FEF3C7" />
                                    </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBookmarked}" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Offset" Width="120" Binding="{Binding OffsetText}" />
                                <DataGridTextColumn Header="Hex (16 bytes)" Width="*" Binding="{Binding HexText}" />
                                <DataGridTextColumn Header="ASCII" Width="260" Binding="{Binding AsciiText}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelCard}" Margin="18,0,0,0">
                <StackPanel>
                    <TextBlock Text="File info" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10" />
                    <TextBlock Text="Load a file and inspect byte layout in 16-byte chunks." Style="{StaticResource FeatureText}" />
                    <TextBlock Text="Search hex patterns, navigate by offset, and jump directly to matches." Style="{StaticResource FeatureText}" />
                    <TextBlock Text="Edit a byte directly by offset, then save and create a reproducible dump." Style="{StaticResource FeatureText}" />
                    <TextBlock Text="Bookmark offsets that matter (headers, signatures, metadata offsets) and return quickly." Style="{StaticResource FeatureText}" />
                    <Separator Margin="0,10,0,10" />
                    <TextBlock Text="Current file:" FontWeight="SemiBold" />
                    <TextBlock x:Name="FilePathText" Text="No file loaded." TextWrapping="Wrap" Foreground="#475569" Margin="0,0,0,12" />
                    <TextBlock Text="Properties:" FontWeight="SemiBold" />
                    <TextBlock x:Name="FileMetricsText" Text="—" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <TextBlock Text="Selection / checksum status:" FontWeight="SemiBold" />
                    <TextBlock x:Name="SelectionText" Text="No selection." Foreground="#475569" TextWrapping="Wrap" />
                    <Separator Margin="0,10,0,10" />
                    <TextBlock Text="License / trial status:" FontWeight="SemiBold" />
                    <TextBlock x:Name="LicenseStatusText" Text="Trial status unknown." Foreground="#0F172A" Margin="0,0,0,6" />
                    <TextBlock x:Name="TrialRemainingText" Text="—" Foreground="#334155" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="ViewLogsButton" Content="View Logs" Click="OnViewLogs" Width="110" />
                        <Button x:Name="AboutButton" Content="About" Click="OnShowAbout" Width="110" />
                    </StackPanel>
                    <TextBlock Text="Undo / Redo:" FontWeight="SemiBold" Margin="0,10,0,0" />
                    <TextBlock x:Name="UndoRedoText" Text="Undo: 0, Redo: 0" Foreground="#475569" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E2E8F0" Padding="18,10">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="#334155" />
        </Border>
    </Grid>
</Window>
